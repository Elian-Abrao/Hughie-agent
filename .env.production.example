# Broker provider settings
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=

# Optional compose variables for deploy scripts
IMAGE_NAMESPACE=ghcr.io/example-owner/hughie-agent
IMAGE_TAG=latest
