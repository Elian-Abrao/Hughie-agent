# Production application settings
HUGHIE_DATABASE_URL=postgresql://hughie:hughie@db:5432/hughie
HUGHIE_GOOGLE_API_KEY=
HUGHIE_BRIDGE_URL=http://broker:47831
HUGHIE_BRIDGE_MODEL=gpt-5.4
